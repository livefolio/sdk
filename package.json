{
  "name": "@livefolio/sdk",
  "version": "0.1.0",
  "description": "Livefolio SDK — market data, strategy evaluation, and portfolio management",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./market": {
      "types": "./dist/market/index.d.ts",
      "default": "./dist/market/index.js"
    },
    "./evaluator": {
      "types": "./dist/evaluator/index.d.ts",
      "default": "./dist/evaluator/index.js"
    },
    "./portfolio": {
      "types": "./dist/portfolio/index.d.ts",
      "default": "./dist/portfolio/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "default": "./dist/auth/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@livefolio/db": "*",
    "@supabase/supabase-js": "^2"
  },
  "devDependencies": {
    "typescript": "^5.5.3"
  }
}
